rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /fileCards/{cardId} {
      // Cards under a deactivated folder are hidden from the public.
      // Cards without a folder default to folderIsActive == true.
      allow read: if (
        resource.data.isActive == true &&
        resource.data.get('folderIsActive', true) == true
      ) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /fileFolders/{folderId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adminUsers/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    match /fcmTokens/{tokenId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    match /notifications/{id} {
      allow read, write: if isAdmin();
    }
  }
}
