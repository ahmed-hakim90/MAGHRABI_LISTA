rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Must match NEXT_PUBLIC_FIREBASE_STORAGE_FOLDER (e.g. magrabi-lista). Redeploy when the folder changes.
    match /magrabi-lista/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
